# Copy to .env and fill in for local runs / CI secrets
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser
MYSQL_PASSWORD=changeme_wp
WORDPRESS_PORT=8080

# Registry push (GitHub Actions secrets)
DOCKERHUB_USERNAME=your-dockerhub-user
DOCKERHUB_TOKEN=your-dockerhub-token
GHCR_IMAGE=ghcr.io/iulianigas/wordpress-hardened
DOCKERHUB_IMAGE=iulianigas/wordpress-hardened
